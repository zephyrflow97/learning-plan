// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // 生产环境改为 "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户与认证相关（NextAuth 需要的表）
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // 邮箱密码登录,bcrypt 加密
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关系
  accounts      Account[]
  sessions      Session[]
  ownedProjects ProjectMember[] @relation("UserProjects")
  assignedTasks Task[]          @relation("AssignedTasks")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// 核心业务表
// ============================================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?  // 项目颜色标识（hex 值,如 "#3b82f6"）
  icon        String?  // 项目图标（emoji 或 icon 名称）
  deadline    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关系
  members     ProjectMember[]
  tasks       Task[]

  @@index([createdAt])
}

model ProjectMember {
  id        String   @id @default(cuid())
  role      Role     @default(MEMBER)
  joinedAt  DateTime @default(now())

  // 关系
  userId    String
  user      User     @relation("UserProjects", fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId]) // 一个用户在一个项目中只能有一个角色
  @@index([projectId])
  @@index([userId])
}

enum Role {
  OWNER   // 项目拥有者（可删除项目、管理成员）
  MEMBER  // 普通成员（可创建/编辑任务）
  VIEWER  // 只读成员（只能查看）
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  order       Int          @default(0) // 看板内排序（拖拽时更新）
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // 关系
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  tags        TaskTag[]

  @@index([projectId, status]) // 查询某项目的某状态任务（看板常用）
  @@index([assigneeId])
  @@index([createdAt])
}

enum TaskStatus {
  TODO        // 待办
  IN_PROGRESS // 进行中
  DONE        // 已完成
}

enum TaskPriority {
  LOW    // 低优先级
  MEDIUM // 中等优先级
  HIGH   // 高优先级
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String    // 标签颜色（hex 值）
  tasks     TaskTag[]
  createdAt DateTime  @default(now())
}

// 任务与标签的多对多关系表
model TaskTag {
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([taskId])
  @@index([tagId])
}

# .env.example - 环境变量模板
# ⚠️ 这个文件应该提交到 Git,作为文档说明
# ⚠️ 真实的值应该在 .env.local 中(不提交到 Git)

# ========== 数据库 ==========
# PostgreSQL 连接字符串
# 格式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# 本地开发示例: postgresql://postgres:postgres@localhost:5432/myapp_dev
# 生产环境(Neon): postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/myapp
DATABASE_URL=postgresql://...

# ========== 认证 (NextAuth) ==========
# JWT 签名密钥(至少 32 字符)
# 生成方式: npx auth secret
NEXTAUTH_SECRET=your-secret-here-min-32-chars

# 应用 URL
# 本地开发: http://localhost:3000
# 生产环境: https://yourapp.com
NEXTAUTH_URL=http://localhost:3000

# ========== GitHub OAuth ==========
# 在 https://github.com/settings/developers 创建 OAuth App
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# ========== Google OAuth (可选) ==========
# 在 https://console.cloud.google.com/apis/credentials 创建 OAuth 2.0 客户端
GOOGLE_ID=your-google-client-id
GOOGLE_SECRET=your-google-client-secret

# ========== Sentry (错误追踪) ==========
# 服务端 DSN(不暴露给客户端)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# 客户端 DSN(会暴露给浏览器,使用 NEXT_PUBLIC_ 前缀)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ========== 客户端公开变量 ==========
# 应用名称
NEXT_PUBLIC_APP_NAME=MyApp

# API 端点
# 本地: http://localhost:3000/api
# 生产: https://yourapp.com/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ========== Vercel 系统变量(自动设置,无需手动配置) ==========
# VERCEL=1
# VERCEL_URL=myapp-xxx.vercel.app
# VERCEL_ENV=production | preview | development
# VERCEL_GIT_COMMIT_SHA=abc123...

# ========== 可选:第三方服务 ==========
# Stripe (支付)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (邮件)
# RESEND_API_KEY=re_...

# Uploadthing (文件上传)
# UPLOADTHING_SECRET=sk_...
# UPLOADTHING_APP_ID=...

# ========== 开发工具 ==========
# 跳过环境变量验证(用于 Docker 构建等特殊场景)
# SKIP_ENV_VALIDATION=true
